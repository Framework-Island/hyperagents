    },
    "engines": {
        "node": ">=18.0.0"
    },
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "dev": "tsx watch src/index.ts",
        "example:bash": "tsx examples/bash/run.ts",
        "example:paper-review": "tsx examples/paper_review/run.ts",
        "demo:scoring": "tsx examples/scoring/run.ts",
        "demo:calculator": "tsx examples/calculator/run.ts",
    "demo:git-evolution": "tsx examples/git_evolution/run.ts",
