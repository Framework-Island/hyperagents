        "self-improving",
        "langchain",
        "langgraph",
        "evolutionary"
    ],
    "license": "MIT",
    "dependencies": {
        "@langchain/anthropic": "^1.3.26",
        "@langchain/community": "^1.1.27",
        "@langchain/core": "^1.1.39",
        "@langchain/google-genai": "^2.1.26",
        "@langchain/langgraph": "^1.2.8",
        "@langchain/ollama": "^1.2.6",
        "@langchain/openai": "^1.4.3",
        "commander": "^13.1.0",
        "dockerode": "^4.0.0",
        "dotenv": "^16.4.0",
        "langchain": "^1.3.1",
        "simple-git": "^3.27.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/dockerode": "^3.3.0",
        "@types/node": "^22.0.0",
